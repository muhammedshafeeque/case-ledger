NODE_ENV=development
PORT=3001
DATABASE_URL=postgresql://rtiwatch:rtiwatch_dev@localhost:5432/rti_watch?connection_limit=10
# Reference SQLite path is set in prisma/reference/schema.prisma (file:../../reference/rti-reference.db)
REFERENCE_DATABASE_URL=file:./reference/rti-reference.db
REDIS_URL=redis://localhost:6379
JWT_SECRET=change-me-to-64-char-random-string-minimum-for-production-use
JWT_ACCESS_EXPIRY=1h
JWT_REFRESH_EXPIRY=1h
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef
ALLOWED_ORIGINS=http://localhost:5173
TOTP_ISSUER=Case Ledger

# MinIO (local S3) — start: cd ../docker && docker compose up -d minio minio-init
S3_ENDPOINT=http://localhost:9000
S3_FORCE_PATH_STYLE=true
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_REGION=us-east-1
S3_BUCKET_NAME=rti-watch-evidence-dev
S3_BACKUP_BUCKET=rti-watch-backups-dev

# Production AWS S3 — omit S3_ENDPOINT, set real IAM keys and region
# AWS_REGION=ap-south-1

GROQ_API_KEY=
GROQ_API_BASE=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.3-70b-versatile
SMTP_HOST=
SMTP_PORT=587
SMTP_FROM=alerts@rti-watch.local
SMTP_USER=
SMTP_PASS=

LOOKUP_LIVE_FETCH=true
LOOKUP_FETCH_TIMEOUT_MS=15000
LOOKUP_USER_AGENT=CaseLedger/1.0 (investigation tool)

# Forensic lab — PDF extraction + optional cloud OCR for scans
FORENSIC_OCR_ENABLED=false
FORENSIC_OCR_API_KEY=
# FORENSIC_OCR_API_URL=https://your-ocr-provider/v1/recognize
FORENSIC_MAX_FILE_MB=50
FORENSIC_TESSERACT_LANG=eng
# PDF reports (puppeteer-core — point at system Chromium in Docker worker)
PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium

# db:clear — set CLEAR_USERS=true to wipe login accounts too
