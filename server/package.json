{
  "name": "rti-watch-server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:local": "tsx scripts/run-local.ts",
    "dev:worker": "tsx watch src/worker.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "start:worker": "node dist/worker.js",
    "db:generate": "prisma generate && prisma generate --schema=prisma/reference/schema.prisma",
    "db:migrate": "prisma migrate deploy",
    "db:setup-postgres": "bash scripts/setup-postgres.sh",
    "db:migrate:dev": "prisma migrate dev --name init",
    "db:seed": "tsx prisma/seed.ts",
    "db:clear": "tsx scripts/clear-app-data.ts",
    "db:studio": "prisma studio",
    "test": "vitest run",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/s3-request-presigner": "^3.700.0",
    "@electric-sql/pglite": "^0.4.5",
    "@prisma/client": "^6.1.0",
    "@types/morgan": "^1.9.10",
    "archiver": "^8.0.0",
    "bcrypt": "^5.1.1",
    "bullmq": "^5.34.0",
    "cheerio": "^1.2.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "exifr": "^7.1.3",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "ioredis": "^5.4.2",
    "jose": "^5.9.6",
    "morgan": "^1.10.1",
    "multer": "^1.4.5-lts.1",
    "otplib": "^12.0.1",
    "pdf-parse": "^2.4.5",
    "pglite-prisma-adapter": "^0.7.2",
    "puppeteer-core": "^24.43.1",
    "tesseract.js": "^5.1.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cookie-parser": "^1.4.8",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.10.2",
    "prisma": "^6.1.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
