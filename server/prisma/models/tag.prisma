model Tag {
  id    String @id @default(uuid()) @db.Uuid
  name  String @unique
  caseTags CaseTag[]

  @@map("tags")
}

model CaseTag {
  caseId String @map("case_id") @db.Uuid
  tagId  String @map("tag_id") @db.Uuid

  case RtiCase @relation(fields: [caseId], references: [id], onDelete: Cascade)
  tag  Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([caseId, tagId])
  @@map("case_tags")
}
