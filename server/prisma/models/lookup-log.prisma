model LookupLog {
  id            String   @id @default(uuid()) @db.Uuid
  userId        String   @map("user_id") @db.Uuid
  caseId        String?  @map("case_id") @db.Uuid
  source        String
  url           String
  query         Json     @default("{}")
  dataRetrieved Json?    @map("data_retrieved")
  decision      String   @default("pending_review")
  fetchMode     String?  @map("fetch_mode")
  createdAt     DateTime @default(now()) @map("created_at")

  case RtiCase? @relation(fields: [caseId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([caseId])
  @@map("lookup_logs")
}
